# Copy this file to .env.local and paste your Anthropic API key.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Set to 1 only for a public demo that should block live Anthropic extraction.
DEMO_ONLY=0

# OPTIONAL: enables live address autocomplete on the Address field.
# Without it, the address field still works and still auto-fills from documents.
# Get a key at https://console.cloud.google.com/ (enable "Places API").
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
